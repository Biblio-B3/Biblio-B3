        "drizzle-zod": "^0.8.2",
        "express": "^5.1.0",
        "hash-wasm": "^4.12.0",
        "helmet": "^8.1.0",
        "jose": "^6.0.11",
        "node-cron": "^4.1.0",
        "node-isbn": "^1.6.1",
        "nodemailer": "^7.0.3",
        "pg": "^8.16.0",
        "xss": "^1.0.15",
        "zod": "^3.25.56"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "moduleDirectories": [
            "node_modules",
            "src"
